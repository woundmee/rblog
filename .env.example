# Required in production
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=scrypt\$16384\$8\$1\$replace_salt\$replace_digest
ADMIN_SECRET=replace_with_long_random_secret_at_least_32_chars

# Optional hardening and tuning
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_RATE_LIMIT_WINDOW_SECONDS=900
ADMIN_RATE_LIMIT_LOCK_SECONDS=900
# Set to 1 only if your reverse proxy strips untrusted x-forwarded-* headers.
TRUST_PROXY_HEADERS=0

# Development-only fallback if ADMIN_PASSWORD_HASH is not set.
# Do not use plain password in production.
ADMIN_PASSWORD=change-me
